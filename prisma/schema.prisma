generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // CommonJS + imports sin extensión: funciona tanto en dev (ts-node → .ts)
  // como en producción compilada (node → .js).
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

// ─── ROLES & USUARIOS ────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  FARMACEUTICO
  CLIENTE
}

model Usuario {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  rol          Rol       @default(CLIENTE)
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  cliente      Cliente?
  ventas       Venta[]   @relation("VentaFarmaceutico")

  @@map("usuarios")
}

model Cliente {
  id              Int       @id @default(autoincrement())
  usuarioId       Int       @unique @map("usuario_id")
  nombres         String
  apellidos       String
  dpi             String?   @unique
  nit             String?
  telefono        String?
  direccion       String?
  fechaNacimiento DateTime? @map("fecha_nacimiento")

  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  ventas          Venta[]
  recetas         Receta[]

  @@map("clientes")
}

// ─── CATÁLOGO ─────────────────────────────────────────────────────────────────

model Categoria {
  id         Int         @id @default(autoincrement())
  nombre     String      @unique
  parentId   Int?        @map("parent_id")

  parent     Categoria?  @relation("Subcategorias", fields: [parentId], references: [id])
  hijos      Categoria[] @relation("Subcategorias")
  productos  Producto[]

  @@map("categorias")
}

model Laboratorio {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  pais      String?

  productos Producto[]

  @@map("laboratorios")
}

model Producto {
  id               Int       @id @default(autoincrement())
  nombre           String
  codigoBarras     String?   @unique @map("codigo_barras")
  descripcion      String?
  imagen           String?   @db.Text
  presentacion     String?
  concentracion    String?
  // `unidadBase` es lo que cuenta el stock (Pastilla, Frasco, Tubo...) y
  // `precioVenta` es el precio de UNA unidad base. Las formas extra de venta
  // (Blíster, Caja) viven en `unidadesVenta`, cada una con su equivalencia y precio.
  unidadBase       String    @default("Unidad") @map("unidad_base")
  precioVenta      Decimal   @map("precio_venta") @db.Decimal(10, 2)
  stock            Int       @default(0)
  stockMinimo      Int       @default(5) @map("stock_minimo")
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  requiereReceta   Boolean   @default(false) @map("requiere_receta")
  activo           Boolean   @default(true)
  categoriaId      Int?      @map("categoria_id")
  laboratorioId    Int?      @map("laboratorio_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  categoria        Categoria?  @relation(fields: [categoriaId], references: [id])
  laboratorio      Laboratorio? @relation(fields: [laboratorioId], references: [id])
  unidadesVenta    UnidadVenta[]
  entradas         EntradaStock[]
  detalleCompras   DetalleCompra[]
  detalleVentas    DetalleVenta[]
  detalleRecetas   DetalleReceta[]

  @@map("productos")
}

// Formas extra de vender un producto, además de su unidad base.
// Ej. para una pastilla (unidad base "Pastilla", Q1.00):
//   { nombre: "Blíster", equivale: 10,  precio: 8.00  }
//   { nombre: "Caja",    equivale: 100, precio: 70.00 }
// Vender 1 Blíster descuenta 10 del stock y cobra Q8.00.
// Un producto que solo se vende de una forma (un jarabe) no tiene ninguna.
model UnidadVenta {
  id         Int      @id @default(autoincrement())
  productoId Int      @map("producto_id")
  nombre     String
  equivale   Int      // cuántas unidades base contiene
  precio     Decimal  @db.Decimal(10, 2)

  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, nombre])
  @@map("unidades_venta")
}

// Cada ingreso de mercadería con su propio vencimiento.
// Es interna: el usuario nunca la ve ni la escribe. Permite que un mismo
// producto tenga unidades con fechas de vencimiento distintas.
// `Producto.stock` y `Producto.fechaVencimiento` se derivan de aquí.
model EntradaStock {
  id               Int       @id @default(autoincrement())
  productoId       Int       @map("producto_id")
  cantidad         Int       // unidades que quedan de esta entrada
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  createdAt        DateTime  @default(now()) @map("created_at")

  producto      Producto       @relation(fields: [productoId], references: [id])
  detalleCompra DetalleCompra?

  @@map("entradas_stock")
}

// ─── PROVEEDORES & COMPRAS ────────────────────────────────────────────────────

model Proveedor {
  id        Int       @id @default(autoincrement())
  nombre    String
  ruc       String?   @unique
  contacto  String?
  telefono  String?
  email     String?
  activo    Boolean   @default(true)

  compras   Compra[]

  @@map("proveedores")
}

model Compra {
  id           Int            @id @default(autoincrement())
  proveedorId  Int?           @map("proveedor_id")
  fecha        DateTime       @default(now())
  total        Decimal        @db.Decimal(10, 2)
  estado       EstadoCompra   @default(PENDIENTE)
  observacion  String?

  proveedor    Proveedor?     @relation(fields: [proveedorId], references: [id])
  detalles     DetalleCompra[]

  @@map("compras")
}

enum EstadoCompra {
  PENDIENTE
  RECIBIDA
  ANULADA
}

model DetalleCompra {
  id          Int      @id @default(autoincrement())
  compraId    Int      @map("compra_id")
  productoId  Int      @map("producto_id")
  entradaId   Int?     @unique @map("entrada_id")
  // Forma en que entró la mercadería (ej. 2 Cajas de 100 = 200 al stock)
  unidadNombre   String @default("Unidad") @map("unidad_nombre")
  unidadEquivale Int    @default(1) @map("unidad_equivale")
  cantidad    Int      // cantidad en la unidad comprada (ej. 2 cajas)
  precioCosto Decimal  @map("precio_costo") @db.Decimal(10, 2) // costo de UNA unidad comprada

  compra      Compra        @relation(fields: [compraId], references: [id])
  producto    Producto      @relation(fields: [productoId], references: [id])
  entrada     EntradaStock? @relation(fields: [entradaId], references: [id])

  @@map("detalle_compras")
}

// ─── RECETAS MÉDICAS ──────────────────────────────────────────────────────────

model Medico {
  id              Int      @id @default(autoincrement())
  nombres         String
  apellidos       String
  nroColegiatura  String?  @unique @map("nro_colegiatura")
  especialidad    String?

  recetas         Receta[]

  @@map("medicos")
}

model Receta {
  id         Int           @id @default(autoincrement())
  clienteId  Int           @map("cliente_id")
  medicoId   Int?          @map("medico_id")
  fecha      DateTime      @default(now())
  imagen     String?
  estado     EstadoReceta  @default(PENDIENTE)

  cliente    Cliente       @relation(fields: [clienteId], references: [id])
  medico     Medico?       @relation(fields: [medicoId], references: [id])
  detalles   DetalleReceta[]
  ventas     Venta[]

  @@map("recetas")
}

enum EstadoReceta {
  PENDIENTE
  DISPENSADA
  PARCIAL
  VENCIDA
}

model DetalleReceta {
  id                  Int      @id @default(autoincrement())
  recetaId            Int      @map("receta_id")
  productoId          Int      @map("producto_id")
  cantidadPrescrita   Int      @map("cantidad_prescrita")
  indicaciones        String?

  receta              Receta   @relation(fields: [recetaId], references: [id])
  producto            Producto @relation(fields: [productoId], references: [id])

  @@map("detalle_recetas")
}

// ─── VENTAS / POS ─────────────────────────────────────────────────────────────

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  YAPE
  PLIN
}

enum EstadoVenta {
  COMPLETADA
  ANULADA
}

model Venta {
  id              Int          @id @default(autoincrement())
  farmaceuticoId  Int          @map("farmaceutico_id")
  clienteId       Int?         @map("cliente_id")
  recetaId        Int?         @map("receta_id")
  fecha           DateTime     @default(now())
  total           Decimal      @db.Decimal(10, 2)
  metodoPago      MetodoPago   @default(EFECTIVO) @map("metodo_pago")
  estado          EstadoVenta  @default(COMPLETADA)
  observacion     String?

  farmaceutico    Usuario      @relation("VentaFarmaceutico", fields: [farmaceuticoId], references: [id])
  cliente         Cliente?     @relation(fields: [clienteId], references: [id])
  receta          Receta?      @relation(fields: [recetaId], references: [id])
  detalles        DetalleVenta[]

  @@map("ventas")
}

model DetalleVenta {
  id          Int      @id @default(autoincrement())
  ventaId     Int      @map("venta_id")
  productoId  Int      @map("producto_id")
  // Forma en que se vendió (se guarda el nombre y la equivalencia del momento,
  // para que el historial no cambie si luego se editan los precios o unidades).
  unidadNombre   String @default("Unidad") @map("unidad_nombre")
  unidadEquivale Int    @default(1) @map("unidad_equivale")
  cantidad    Int      // cantidad en la unidad vendida (ej. 2 blísters)
  precioUnit  Decimal  @map("precio_unit") @db.Decimal(10, 2) // precio de UNA unidad vendida
  subtotal    Decimal  @db.Decimal(10, 2)

  venta       Venta    @relation(fields: [ventaId], references: [id])
  producto    Producto @relation(fields: [productoId], references: [id])

  @@map("detalle_ventas")
}
