# Copia este archivo a ".env" y coloca valores reales antes de desplegar.
#   cp .env.example .env

# Credenciales de la base de datos
DB_USER=farmavida_user
DB_PASSWORD=cambia_esta_contrasena
DB_NAME=farmavida_db
DB_PORT=5433

# Cadena de conexión.
#  - Desarrollo local:  usa localhost y el puerto DB_PORT
#  - Producción (Docker): el docker-compose la construye apuntando al servicio "postgres"
DATABASE_URL="postgresql://farmavida_user:cambia_esta_contrasena@localhost:5433/farmavida_db?sslmode=disable"

# IMPORTANTE: en producción usa un secreto largo y aleatorio (p. ej. `openssl rand -hex 32`)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Puerto del backend
PORT=3000

# ─── Notificaciones por correo (Gmail / Google Workspace) ─────────────────────
# Opcional: si se dejan vacías, el sistema no envía correos y todo lo demás
# sigue funcionando normal.

# Correo de la farmacia que ENVÍA los avisos
SMTP_USER=farmavida@gmail.com
# Contraseña de aplicación de 16 caracteres (NO la contraseña normal de la cuenta).
# Requiere tener activada la verificación en 2 pasos:
#   1) https://myaccount.google.com/signinoptions/twosv
#   2) https://myaccount.google.com/apppasswords
SMTP_PASS=abcdefghijklmnop
# Correo de la dueña, que RECIBE los avisos
NOTIFY_EMAIL=duena@ejemplo.com
